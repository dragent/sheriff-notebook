# Ne pas commiter de vraies valeurs. Copier en .env.local et remplir avec tes secrets.

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_long_random_secret

DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Doit être identique à BACKEND_JWT_SECRET du backend
BACKEND_JWT_SECRET=your_long_random_jwt_secret

# URL du backend. Adapter selon l’environnement :
# - Docker : http://backend
# - Local : http://localhost:8080 (ou 8000 si symfony serve)
BACKEND_BASE_URL=http://localhost:8080

# Optionnel (utilisées par le backend pour le pseudo serveur Discord) :
# Si vous lancez avec Docker depuis la racine, ces variables sont dans .env.local à la racine.
# DISCORD_GUILD_ID=your_discord_guild_id
# DISCORD_BOT_TOKEN=your_discord_bot_token

