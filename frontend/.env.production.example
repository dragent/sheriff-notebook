# Production — sheriffnotebook.dragent.fr
# Copier sur le serveur en .env.local (ou .env) et remplir les valeurs.
# Ne jamais commiter ce fichier une fois rempli.

NEXTAUTH_URL=https://sheriffnotebook.dragent.fr
NEXTAUTH_SECRET=<générer_32_caractères_minimum>

DISCORD_CLIENT_ID=<ton_discord_client_id_prod>
DISCORD_CLIENT_SECRET=<ton_discord_client_secret_prod>

# Doit être identique à BACKEND_JWT_SECRET du backend
BACKEND_JWT_SECRET=<générer_64_caractères_minimum_identique_backend>

BACKEND_BASE_URL=https://api.sheriffnotebook.dragent.fr

# Sentry (optionnel)
# NEXT_PUBLIC_SENTRY_DSN=<dsn_projet_frontend>
# SENTRY_ENVIRONMENT=production
