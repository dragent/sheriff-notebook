# Copy to ".env" for local dev, or rely on Docker: backend Dockerfile creates .env from this file if missing.
# Production secrets: set via root .env.local + docker-compose env_file (not committed).
# https://symfony.com/doc/current/configuration.html#managing-environment-variables

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_generate_a_random_secret
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://sheriff:change_me@db:5432/sheriff?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> app/auth ###
BACKEND_JWT_SECRET=change_me_same_as_frontend_BACKEND_JWT_SECRET
###< app/auth ###

###> app/discord-guild ###
# DISCORD_GUILD_ID=
