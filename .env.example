# Ne pas commiter de vraies valeurs.
# Copier ce fichier en .env.local à la racine pour Docker (backend + frontend).
# Variables listées : voir aussi frontend/.env.local.example pour le détail côté front.

# --- Production / VPS (Docker Compose prod)
# PostgreSQL (container). Use strong values in production.
# POSTGRES_DB=sheriff
# POSTGRES_USER=sheriff
# POSTGRES_PASSWORD=change_me_strong_password
#
# Symfony backend (required in prod)
# APP_SECRET=change_me_strong_app_secret
# DATABASE_URL must be PostgreSQL (migrations are Postgres-specific; MySQL is not supported out of the box).
# DATABASE_URL=postgresql://sheriff:change_me_strong_password@db:5432/sheriff?serverVersion=16&charset=utf8
# CORS_ALLOW_ORIGIN=^https://sheriff\.example\.com$
#
# Frontend → backend calls (inside Docker network)
# BACKEND_BASE_URL=http://backend

# NextAuth (frontend) — one line per variable (do not duplicate NEXTAUTH_URL).
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_long_random_secret

# Discord OAuth2 (frontend)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Secret partagé frontend/backend — doit être identique des deux côtés
BACKEND_JWT_SECRET=your_long_random_jwt_secret
# Optional JWT claims — if set, must match between frontend (BACKEND_JWT_ISS / BACKEND_JWT_AUD) and backend (.env).
# BACKEND_JWT_ISS=
# BACKEND_JWT_AUD=

# Optionnel : pseudo serveur Discord (backend)
# DISCORD_GUILD_ID=your_discord_guild_id
# DISCORD_BOT_TOKEN=your_discord_bot_token
# Optionnel : canal où publier le message effectif (Référentiel → Message effectif Discord)
# DISCORD_EFFECTIF_CHANNEL_ID=your_discord_channel_id
# Optionnel : canal où publier les logs de reset planning
# DISCORD_PLANNING_CHANNEL_ID=your_discord_channel_id

# URL du backend (frontend). Avec Docker : http://backend ; en local : http://localhost:8080
BACKEND_BASE_URL=http://localhost:8080

# Sentry (optionnel — si vide, pas d'envoi d'erreurs). Voir docs/OBSERVABILITY.md.
# NEXT_PUBLIC_SENTRY_DSN=   # DSN projet frontend (public, visible dans le build)
# SENTRY_DSN=               # DSN projet backend (même projet ou projet dédié)
# SENTRY_ENVIRONMENT=production   # En prod : définir explicitement pour filtrer dans Sentry
# Pour l’upload des source maps frontend (CI/CD uniquement, ne pas commiter) :
# SENTRY_ORG=               # Slug de l’organisation Sentry
# SENTRY_PROJECT=           # Slug du projet Sentry
# SENTRY_AUTH_TOKEN=        # Token d’authentification Sentry (settings → Auth Tokens)
